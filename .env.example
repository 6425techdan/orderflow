# OrderFlow local environment template
# Copy to `.env` for local overrides. NEVER commit real secrets.
# Default Compose stack works with built-in compose environment; `.env` is optional.

# --- Core ---
SERVICE_NAME=order-api
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO
DEPLOY_ENV=local

# --- Data stores (local defaults) ---
DATABASE_URL=postgresql://orderflow:orderflow@localhost:5432/orderflow
REDIS_URL=redis://localhost:6379/0
ORDERS_STREAM=orders
ORDERS_GROUP=order-workers
DEAD_LETTER_STREAM=orders-dlq
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- Dependencies ---
PAYMENT_URL=http://localhost:8082

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_ENABLED=true

# --- Fault injection / drills (lab only) ---
FAULT_PAYMENT_LATENCY_MS=0
FAULT_PAYMENT_FAIL_RATE=0.0
FAULT_DB_EXHAUST=false
MENU_VERSION=2026.07.01
STALE_MENU_REJECT=false

# --- Incident assistant ---
# Fixture mode needs no API key. Paid model = STOP gate (do not set casually).
# INCIDENT_ASSISTANT_MODE=fixture
# OPENAI_API_KEY=  # leave unset

# --- Azure / Terraform (optional; do not apply without approval) ---
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# Never store AZURE_CLIENT_SECRET when using OIDC (see docs/oidc-azure.md)

# --- Teardown helpers ---
# ORDERFLOW_DELETE_KIND=0
# ORDERFLOW_KIND_CLUSTER=orderflow
# ORDERFLOW_ALLOW_COMPOSE_RECREATE=0
